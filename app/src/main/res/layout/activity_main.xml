<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cookie提取器"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="抖音"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_get_douyin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取抖音Cookie"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#FF0000"/>

                <TextView
                    android:id="@+id/tv_douyin_cookie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="未获取"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:maxLines="5"
                    android:ellipsize="end"
                    android:background="#F5F5F5"
                    android:padding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="哔哩哔哩"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_get_bilibili"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取B站Cookie"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#00A1D6"/>

                <TextView
                    android:id="@+id/tv_bilibili_cookie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="未获取"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:maxLines="5"
                    android:ellipsize="end"
                    android:background="#F5F5F5"
                    android:padding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="小黑盒"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_get_xiaoheihe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取小黑盒Cookie"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#333333"/>

                <TextView
                    android:id="@+id/tv_xiaoheihe_cookie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="未获取"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:maxLines="5"
                    android:ellipsize="end"
                    android:background="#F5F5F5"
                    android:padding="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_get_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="一键获取所有Cookie"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4CAF50"
            android:textSize="16sp"
            android:padding="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="使用说明：点击按钮打开平台，登录后自动提取Cookie"
            android:textSize="14sp"
            android:textColor="#666666"/>

    </LinearLayout>

</ScrollView>
